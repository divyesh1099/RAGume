DATABASE_URL=sqlite:///./data/app.db
UPLOADS_DIR=./data/uploads
RESUME_PARSER_BACKEND=auto
MAX_CHUNK_CHARS=1200
CHUNK_OVERLAP_CHARS=160
CLAIM_CONTEXT_TOP_K=6
MAX_CLAIMS_PER_RUN=10
ENABLE_LLM_EXTRACTOR=false
ENABLE_EMBEDDING_RETRIEVAL=false
ENABLE_CORRECTION_LLM_ARBITER=false
ENABLE_RESUME_NER=true
ENABLE_RESUME_GPT_FORMATTER=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
CORRECTION_EMBEDDING_PROVIDER=openai
CORRECTION_LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CORRECTION_LOCAL_EMBEDDING_CACHE_DIR=./data/model-cache
CORRECTION_ARBITER_PROVIDER=openai
CORRECTION_ARBITER_MODEL=
CORRECTION_ARBITER_MIN_SCORE=0.65
CORRECTION_ARBITER_MAX_SCORE=0.9
CORRECTION_ARBITER_MARGIN=0.12
CORRECTION_ARBITER_CANDIDATE_LIMIT=4
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_ARBITER_MODEL=
RESUME_FORMATTER_MODEL=
RESUME_NER_MODEL_ID=oksomu/resume-ner
RESUME_NER_CACHE_DIR=./data/model-cache
RESUME_NER_MAX_TOKENS=512
